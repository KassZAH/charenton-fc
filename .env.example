# URL du projet Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé publique "anon" (Project Settings > API) — safe côté navigateur, protégée par Row Level Security
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé "service_role" (Project Settings > API) — accès total, contourne RLS.
# NE JAMAIS l'exposer au navigateur. Utilisée uniquement dans du code serveur (Server Actions, Route Handlers).
SUPABASE_SERVICE_ROLE_KEY=

# Secret aléatoire pour signer les cookies de session (auth par PIN).
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
